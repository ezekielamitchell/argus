# ------------------------------------------------------------
*.log
logs/
tmp/
*.tmp
*~
*.bak
*.orig
*.old

# ------------------------------------------------------------
# Keep-exceptions
# Re-include small, intentionally-committed artifacts that the broad rules
# above would otherwise ignore. NOTE: there is deliberately NO blanket
# re-include for data/ (e.g. !data/sample/**). Everything under data/ is PII
# by default; committing a sample must be a conscious, per-file `git add -f`
# so reviewed-and-de-identified is the only way data leaves a machine.
# ------------------------------------------------------------
!**/.gitkeep
!tests/**/fixtures/**
!tests/**/*.npy
!tests/**/*.npz
