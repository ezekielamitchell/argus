# DVC: ignore local cache/tmp, keep .dvc/config and *.dvc pointer files.
/.dvc/cache
/.dvc/tmp
/.dvc/config.local

# ------------------------------------------------------------
# Datasets, media & large artifacts (CASEset streams, captures)
#
# The ENTIRE data/ tree is local-only. CASEset recordings — webcam frames,
# screenshots, gaze, interaction logs, manifests — live under
# data/caseset/sessions/... and must NEVER be committed (see docs/ETHICS.md,
# docs/DATASET.md). Only the folder's own README and .gitkeep are tracked.
# This is enforced regardless of file extension, which is why we do NOT rely
# on the per-extension media rules below for anything under data/.
# To share a small, reviewed, de-identified sample, force-add the specific
# file explicitly:  git add -f data/sample/<file>
# ------------------------------------------------------------
/data/**
!/data/README.md
!/data/.gitkeep

# Generic capture/derived-artifact dirs anywhere else in the tree
recordings/
frames/

# Arrays / columnar / record stores
*.npy
*.npz
*.tfrecord
*.lmdb
*.mdb
*.parquet
*.feather
*.arrow

